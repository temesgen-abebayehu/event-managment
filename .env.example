# For Docker Compose — copy this to .env and fill in your values
# IMPORTANT: JWT_SECRET must be identical across Hasura and Backend

# Security
HASURA_ADMIN_SECRET=change-this-admin-secret
JWT_SECRET=your-jwt-secret-must-be-at-least-32-chars

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Chapa Payment
CHAPA_SECRET_KEY=your-chapa-secret
CHAPA_PUBLIC_KEY=your-chapa-public
CHAPA_CALLBACK_URL=http://localhost:3001/webhook/chapa
CHAPA_RETURN_URL=http://localhost:3000/payment/success
